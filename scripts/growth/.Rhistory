# signed log p-values helper
signed_logp <- function(res) {
source <- res[!is.na(res$pvalue), ]
out <- data.frame(gene = rownames(source))
out$lpv <- -log10(source$pvalue)
out$lpv[source$stat < 0] <- out$lpv[source$stat < 0] * -1
out
}
genotype.p <- signed_logp(genotype)
fate.p <- signed_logp(fate)
write.csv(genotype.p, file = file.path(outdir, "genotype_lpv.csv"), row.names = FALSE, quote = FALSE)
write.csv(fate.p,     file = file.path(outdir, "fate_lpv.csv"),     row.names = FALSE, quote = FALSE)
# fold-change tables for pairwise contrasts
fc_table <- function(res) {
source <- res[!is.na(res$pvalue), ]
data.frame(gene = rownames(source), lfc = source$log2FoldChange)
}
write.csv(fc_table(diseased_healthy), file = file.path(outdir, "diseased_healthy_fc.csv"), row.names = FALSE, quote = FALSE)
write.csv(fc_table(nai_healthy),      file = file.path(outdir, "nai_healthy_fc.csv"),      row.names = FALSE, quote = FALSE)
write.csv(fc_table(diseased_nai),     file = file.path(outdir, "diseased_nai_fc.csv"),     row.names = FALSE, quote = FALSE)
write.csv(signed_logp(diseased_healthy), file = file.path(outdir, "diseased_healthy_lpv.csv"), row.names = FALSE, quote = FALSE)
write.csv(signed_logp(nai_healthy),      file = file.path(outdir, "nai_healthy_lpv.csv"),      row.names = FALSE, quote = FALSE)
write.csv(signed_logp(diseased_nai),     file = file.path(outdir, "diseased_nai_lpv.csv"),     row.names = FALSE, quote = FALSE)
